---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';
import FinalCTA from '~/components/FinalCTA.astro';
import { t } from '~/i18n/ui';
import { COMPETITORS, getCompetitorContent, competitorTitle, competitorDescription, COMPETITOR_LABELS, type CompetitorSlug } from '~/data/competitors';

export const getStaticPaths: GetStaticPaths = () => {
  return COMPETITORS.map((competitor) => ({ params: { competitor } }));
};

const { competitor } = Astro.params as { competitor: CompetitorSlug };
const locale = 'en' as const;
const ui = t(locale);
const labels = COMPETITOR_LABELS[locale];
const content = getCompetitorContent(competitor, locale);
const title = competitorTitle(competitor, locale);
const description = competitorDescription(competitor, locale);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  inLanguage: 'en-US',
  author: { '@type': 'Organization', name: 'KeyAI' },
  publisher: { '@type': 'Organization', name: 'KeyAI' },
  datePublished: '2026-05-11',
  dateModified: '2026-05-11',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: content.rows.map((row, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: row.feature,
  })),
};

function fmt(v: string | boolean): string {
  if (v === true) return '✓';
  if (v === false) return '—';
  return v;
}
---

<BaseLayout
  locale={locale}
  path={`/vs/${competitor}`}
  title={title}
  description={description}
  schema={[articleSchema, itemListSchema]}
>
  <Nav locale={locale} />
  <main>
    <section class="pt-12 sm:pt-16 pb-10">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="text-xs uppercase tracking-[0.2em] text-accent-soft font-medium mb-3">{ui.nav.compare}</div>
        <h1 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl leading-tight">
          <span class="headline-gradient">KeyAI vs {content.name}</span>
        </h1>
        <p class="mt-5 text-base sm:text-lg text-text-muted leading-relaxed">{content.intro}</p>
      </div>
    </section>

    <section class="pb-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="glass rounded-3xl overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-border bg-white/[0.02]">
                <th class="text-left text-xs uppercase tracking-wider text-text-muted font-semibold py-4 px-4 sm:px-6">{labels.feature}</th>
                <th class="text-left text-xs uppercase tracking-wider font-semibold py-4 px-4 sm:px-6">
                  <span class="text-accent-soft">KeyAI</span>
                </th>
                <th class="text-left text-xs uppercase tracking-wider text-text-muted font-semibold py-4 px-4 sm:px-6">{content.name}</th>
              </tr>
            </thead>
            <tbody>
              {content.rows.map((row, i) => (
                <tr class:list={['border-b border-border last:border-0', i % 2 === 1 ? 'bg-white/[0.01]' : '']}>
                  <td class="py-3.5 px-4 sm:px-6 text-sm text-text-muted">{row.feature}</td>
                  <td class="py-3.5 px-4 sm:px-6 text-sm font-medium">
                    <span class:list={[row.keyai === true ? 'text-success' : row.keyai === false ? 'text-text-muted' : 'text-text']}>{fmt(row.keyai)}</span>
                  </td>
                  <td class="py-3.5 px-4 sm:px-6 text-sm">
                    <span class:list={[row.competitor === true ? 'text-success' : row.competitor === false ? 'text-text-muted/60' : 'text-text-muted']}>{fmt(row.competitor)}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="pb-20">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="font-display font-bold text-2xl sm:text-3xl mb-4">
          <span class="headline-gradient">{labels.verdictTitle}</span>
        </h2>
        <p class="text-text-muted leading-relaxed text-base sm:text-lg">{content.verdict}</p>
      </div>
    </section>

    <FinalCTA locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
