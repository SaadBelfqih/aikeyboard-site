---
import { SEO } from 'astro-seo';
import '~/styles/global.css';
import { LOCALES, LOCALE_META, type Locale, localizedPath, stripLocaleFromPath } from '~/i18n/locales';
import { t } from '~/i18n/ui';

interface Props {
  locale: Locale;
  path?: string; // canonical path WITHOUT locale prefix, e.g. "/" or "/features" or "/vs/grammarly"
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { locale, path, title, description, ogImage, noindex, schema } = Astro.props;
const ui = t(locale);
const meta = LOCALE_META[locale];

const cleanPath = path ?? stripLocaleFromPath(Astro.url.pathname);
const SITE = 'https://bestaikeyboard.com';
const canonicalPath = localizedPath(locale, cleanPath);
const canonical = new URL(canonicalPath, SITE).href;

const pageTitle = title ?? ui.meta.title;
const pageDesc = description ?? ui.meta.description;
// Fallback to the app icon as OG until per-locale 1200x630 images are generated.
const ogImg = ogImage ?? `${SITE}/icon-1024.png`;

// hreflang alternates for every locale
const alternates = LOCALES.map((loc) => ({
  hreflang: LOCALE_META[loc].hreflang,
  href: new URL(localizedPath(loc, cleanPath), SITE).href,
}));

// App Store URL with locale tracking
const appStoreCC = meta.appStoreCountry;
const appStoreUrl = `https://apps.apple.com/${appStoreCC}/app/id6466343783?pt=&ct=web-${locale}&mt=8`;

// JSON-LD: site-wide + page-specific
const siteSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'KeyAI',
    url: SITE,
    logo: `${SITE}/icon-512.png`,
    sameAs: [appStoreUrl],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'KeyAI · The Best AI Keyboard',
    url: SITE,
    inLanguage: meta.hreflang,
    potentialAction: {
      '@type': 'SearchAction',
      target: `${SITE}/search?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  },
];

const pageSchemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
const allSchemas = [...siteSchema, ...pageSchemas];
---

<!doctype html>
<html lang={meta.htmlLang} dir={meta.dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a14" />
    <link rel="icon" type="image/png" sizes="100x100" href="/icon-100.png?v=2" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />

    <SEO
      title={pageTitle}
      description={pageDesc}
      canonical={canonical}
      noindex={noindex}
      openGraph={{
        basic: {
          title: ui.meta.ogTitle,
          type: 'website',
          image: ogImg,
          url: canonical,
        },
        optional: {
          description: pageDesc,
          siteName: 'KeyAI',
          locale: meta.hreflang.replace('-', '_'),
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: ui.meta.ogTitle,
        description: pageDesc,
        image: ogImg,
      }}
    />

    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(cleanPath, SITE).href} />

    {allSchemas.map((s) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Google Analytics 4 (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-K0L6Z4JFDD"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-K0L6Z4JFDD');

      // Track App Store badge clicks as a conversion proxy for installs.
      // App Store Connect attributes the install via the ct=web-<locale>
      // referral param already baked into every badge URL.
      document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest && e.target.closest('a[href*="apps.apple.com"]');
        if (!a) return;
        gtag('event', 'app_store_click', {
          event_category: 'outbound',
          event_label: a.href,
          locale: document.documentElement.lang || 'en',
        });
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
