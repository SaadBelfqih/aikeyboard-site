---
import type { Locale } from '~/i18n/locales';
import { t } from '~/i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const ui = t(locale);
---

<section id="faq" class="py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="font-display font-bold text-3xl sm:text-4xl">
        <span class="headline-gradient">{ui.faq.title}</span>
      </h2>
      <p class="mt-3 text-text-muted">{ui.faq.subtitle}</p>
    </div>

    <div class="space-y-2.5">
      {ui.faq.items.map((item) => (
        <details class="group glass rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer hover:bg-white/[0.03] transition-colors">
            <span class="font-medium text-sm sm:text-base">{item.q}</span>
            <span class="grid place-items-center h-7 w-7 rounded-full bg-white/5 transition-transform group-open:rotate-45 shrink-0">
              <svg viewBox="0 0 12 12" class="h-3 w-3" aria-hidden="true">
                <path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </span>
          </summary>
          <div class="px-5 pb-4 text-sm text-text-muted leading-relaxed">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
