---
import type { Locale } from '~/i18n/locales';
import { LOCALES, LOCALE_META, localizedPath, stripLocaleFromPath } from '~/i18n/locales';

interface Props {
  locale: Locale;
  path?: string;
}

const { locale, path } = Astro.props;
const cleanPath = path ?? stripLocaleFromPath(Astro.url.pathname);
---

<div class="relative group">
  <button
    type="button"
    class="inline-flex items-center gap-1.5 rounded-full glass px-3 py-1.5 text-xs font-medium text-text hover:bg-white/5 transition-colors"
    aria-haspopup="true"
  >
    <span aria-hidden="true">{LOCALE_META[locale].flag}</span>
    <span>{LOCALE_META[locale].label}</span>
    <svg class="h-3 w-3 opacity-60" viewBox="0 0 12 12" aria-hidden="true">
      <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
  <div
    class="absolute right-0 top-full mt-2 hidden group-hover:block group-focus-within:block min-w-[220px] rounded-2xl p-2 z-50 border border-white/10 shadow-2xl shadow-black/60"
    style="background-color: rgba(15, 15, 24, 0.96); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);"
  >
    {LOCALES.map((loc) => (
      <a
        href={localizedPath(loc, cleanPath)}
        class:list={[
          'flex items-center gap-2.5 rounded-xl px-3 py-2 text-sm transition-colors hover:bg-white/10',
          loc === locale ? 'text-text font-medium bg-white/5' : 'text-text-muted',
        ]}
        hreflang={LOCALE_META[loc].hreflang}
      >
        <span aria-hidden="true">{LOCALE_META[loc].flag}</span>
        <span>{LOCALE_META[loc].label}</span>
      </a>
    ))}
  </div>
</div>
