---
import type { Locale } from '~/i18n/locales';
import { LOCALE_META } from '~/i18n/locales';

interface Props {
  locale: Locale;
  size?: 'sm' | 'md' | 'lg';
  label?: string;
}

const { locale, size = 'md', label } = Astro.props;
const cc = LOCALE_META[locale].appStoreCountry;
const href = `https://apps.apple.com/${cc}/app/id6466343783?pt=&ct=web-${locale}&mt=8`;

const sizes = {
  sm: 'px-4 py-2.5 text-xs',
  md: 'px-5 py-3 text-sm',
  lg: 'px-7 py-4 text-base',
};
const iconSize = { sm: 'h-4 w-4', md: 'h-5 w-5', lg: 'h-6 w-6' }[size];

const smallLabels: Record<Locale, string> = {
  en: 'Download on the',
  de: 'Laden im',
  fr: 'Disponible sur',
  es: 'Descargar en',
  pt: 'Disponível na',
  'pt-br': 'Baixar na',
};
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  class:list={[
    'inline-flex items-center gap-3 rounded-2xl bg-white text-black font-semibold transition-all hover:scale-[1.03] hover:shadow-2xl hover:shadow-white/20',
    sizes[size],
  ]}
  aria-label={label ?? `Download KeyAI on the App Store`}
>
  <svg viewBox="0 0 24 24" class:list={[iconSize, 'fill-current']} aria-hidden="true">
    <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z" />
  </svg>
  {label ? (
    <span class="font-bold">{label}</span>
  ) : (
    <span class="flex flex-col items-start leading-tight">
      <span class="text-[0.65rem] uppercase tracking-wide text-black/55">{smallLabels[locale]}</span>
      <span class="font-bold">App Store</span>
    </span>
  )}
</a>
