---
import type { Locale } from '~/i18n/locales';
import { t } from '~/i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const ui = t(locale);
---

<section class="py-20 sm:py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="glass-strong rounded-3xl p-8 sm:p-12 relative overflow-hidden">
      <div class="absolute -top-20 -right-20 h-60 w-60 bg-success/20 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="relative flex flex-col sm:flex-row gap-6 items-start">
        <div class="grid place-items-center h-14 w-14 rounded-2xl bg-success/15 text-success border border-success/30 shrink-0">
          <svg viewBox="0 0 24 24" class="h-7 w-7 fill-current" aria-hidden="true">
            <path d="M12 2L4 5v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V5l-8-3zm-1 16l-4-4 1.41-1.41L11 15.17l5.59-5.59L18 11l-7 7z" />
          </svg>
        </div>
        <div>
          <h2 class="font-display font-bold text-2xl sm:text-3xl mb-3">
            <span class="headline-gradient">{ui.privacy.title}</span>
          </h2>
          <p class="text-text-muted leading-relaxed">{ui.privacy.body}</p>
        </div>
      </div>
    </div>
  </div>
</section>
