---
import type { Locale } from '~/i18n/locales';
import { t } from '~/i18n/ui';
import { FEATURES } from '~/i18n/features';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const ui = t(locale);
const features = FEATURES[locale];
---

<section id="features" class="relative py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <div class="text-xs uppercase tracking-[0.2em] text-accent-soft font-medium mb-3">
        {ui.features.sectionEyebrow}
      </div>
      <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl leading-tight">
        <span class="headline-gradient">{ui.features.sectionTitle}</span>
      </h2>
      <p class="mt-4 text-text-muted">{ui.features.sectionSubtitle}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-3 sm:gap-4">
      {features.map((feature, i) => (
        <div class:list={[
          'glass rounded-2xl p-5 hover:bg-white/[0.06] transition-colors',
          i === 0 ? 'sm:col-span-2 lg:col-span-2 xl:col-span-2 bg-gradient-to-br from-accent/15 to-transparent border-accent/30' : '',
        ]}>
          <div class="text-3xl mb-3">{feature.icon}</div>
          <h3 class="font-semibold text-base mb-1.5">{feature.title}</h3>
          <p class="text-sm text-text-muted leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
