---
import type { Locale } from '~/i18n/locales';
import { LOCALE_META } from '~/i18n/locales';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

// Demo conversation + toolbar matching the actual KeyAI iOS keyboard
const demos: Record<Locale, {
  bubbleIn: string;
  bubbleOut: string;
  composer: string;
  toolbar: { label: string; icon: string }[];
}> = {
  en: {
    bubbleIn: 'Hey! Are you free Friday?',
    bubbleOut: "I'd love to. What time works?",
    composer: 'Yeah sure friday works for me',
    toolbar: [
      { icon: '✓',  label: 'Check Grammar' },
      { icon: '♪',  label: 'Tone Changer' },
      { icon: '?',  label: 'Ask AI' },
      { icon: '⇄',  label: 'Translate' },
      { icon: '↻',  label: 'Paraphrase' },
    ],
  },
  de: {
    bubbleIn: 'Hey! Bist du Freitag frei?',
    bubbleOut: 'Sehr gerne. Welche Uhrzeit passt?',
    composer: 'ja klar freitag passt mir',
    toolbar: [
      { icon: '✓',  label: 'Grammatik prüfen' },
      { icon: '♪',  label: 'Tonfall ändern' },
      { icon: '?',  label: 'KI fragen' },
      { icon: '⇄',  label: 'Übersetzen' },
      { icon: '↻',  label: 'Umschreiben' },
    ],
  },
  fr: {
    bubbleIn: 'Salut ! Tu es libre vendredi ?',
    bubbleOut: 'Avec plaisir. Quelle heure te convient ?',
    composer: 'ouais ok vendredi ça marche',
    toolbar: [
      { icon: '✓',  label: 'Grammaire' },
      { icon: '♪',  label: 'Changeur de ton' },
      { icon: '?',  label: "Demander à l'IA" },
      { icon: '⇄',  label: 'Traduire' },
      { icon: '↻',  label: 'Paraphraser' },
    ],
  },
  es: {
    bubbleIn: '¡Hola! ¿Estás libre el viernes?',
    bubbleOut: 'Me encantaría. ¿A qué hora te viene bien?',
    composer: 'si claro el viernes me viene bien',
    toolbar: [
      { icon: '✓',  label: 'Revisar gramática' },
      { icon: '♪',  label: 'Cambio de tono' },
      { icon: '?',  label: 'Preguntar IA' },
      { icon: '⇄',  label: 'Traducir' },
      { icon: '↻',  label: 'Parafrasear' },
    ],
  },
  pt: {
    bubbleIn: 'Olá! Estás livre na sexta?',
    bubbleOut: 'Adorava. A que horas te dá jeito?',
    composer: 'sim claro sexta dá-me jeito',
    toolbar: [
      { icon: '✓',  label: 'Gramática' },
      { icon: '♪',  label: 'Mudança de tom' },
      { icon: '?',  label: 'Perguntar IA' },
      { icon: '⇄',  label: 'Traduzir' },
      { icon: '↻',  label: 'Parafrasear' },
    ],
  },
  'pt-br': {
    bubbleIn: 'Oi! Você tá livre sexta?',
    bubbleOut: 'Adoraria. Que horas funciona pra você?',
    composer: 'sim claro sexta funciona pra mim',
    toolbar: [
      { icon: '✓',  label: 'Gramática' },
      { icon: '♪',  label: 'Mudar tom' },
      { icon: '?',  label: 'Perguntar IA' },
      { icon: '⇄',  label: 'Traduzir' },
      { icon: '↻',  label: 'Parafrasear' },
    ],
  },
};

const d = demos[locale];
const flag = LOCALE_META[locale].flag;

// QWERTY layout (locale-specific would be ideal; en QWERTY works as a visual reference)
const row1 = 'qwertyuiop'.split('');
const row2 = 'asdfghjkl'.split('');
const row3 = 'zxcvbnm'.split('');
---

<div class="relative mx-auto" style="width: 320px;">
  <!-- Glow -->
  <div class="absolute -inset-12 bg-accent/30 blur-3xl rounded-full opacity-60 pointer-events-none" aria-hidden="true"></div>

  <!-- Phone frame -->
  <div class="relative rounded-[3rem] bg-gradient-to-b from-[#1f1f2e] to-[#11111e] p-3 shadow-2xl border border-white/10">
    <div class="rounded-[2.5rem] overflow-hidden bg-[#0e0e18] aspect-[9/19.5] relative">
      <!-- Status bar / notch -->
      <div class="h-7 bg-[#0e0e18] flex items-center justify-center relative">
        <div class="absolute top-2 left-1/2 -translate-x-1/2 h-5 w-24 bg-black rounded-full"></div>
      </div>

      <!-- Chat header -->
      <div class="px-4 py-2 flex items-center gap-2 border-b border-white/5">
        <button class="text-accent text-lg" aria-hidden="true">‹</button>
        <div class="h-8 w-8 rounded-full overflow-hidden bg-gradient-to-br from-pink-400 to-purple-500">
          <img src="/avatars/u3.jpg" alt="" class="h-full w-full object-cover" loading="lazy" width="32" height="32" />
        </div>
        <div class="text-sm font-medium">Alex</div>
      </div>

      <!-- Messages -->
      <div class="px-4 py-3 space-y-2 text-[13px]">
        <div class="flex">
          <div class="bg-[#2a2a3a] rounded-2xl rounded-tl-md px-3 py-2 max-w-[80%]">
            {d.bubbleIn}
          </div>
        </div>
        <div class="flex justify-end">
          <div class="bg-gradient-to-br from-accent to-accent-soft rounded-2xl rounded-tr-md px-3 py-2 max-w-[80%] text-white">
            {d.bubbleOut}
          </div>
        </div>
      </div>

      <!-- Composer + KeyAI keyboard -->
      <div class="absolute bottom-0 inset-x-0">
        <!-- Composer -->
        <div class="px-3 py-2 border-t border-white/5 bg-[#0e0e18]">
          <div class="rounded-full bg-[#1f1f2e] px-3 py-1.5 text-xs text-text-muted">
            {d.composer}
          </div>
        </div>

        <!-- KeyAI top toolbar — matches the actual iOS app -->
        <!-- Light keyboard background like iOS system keyboard -->
        <div class="bg-[#d1d4dc] px-1.5 pt-1.5 pb-0.5">
          <div class="flex items-center gap-1 overflow-hidden">
            <!-- Feature pill buttons (white rounded, black text, 14px-equivalent) -->
            {d.toolbar.slice(0, 3).map((tool) => (
              <div class="flex items-center gap-1 bg-white text-black rounded-[10px] px-1.5 py-1 text-[9px] font-semibold whitespace-nowrap shadow-sm">
                <span class="text-[10px] leading-none">{tool.icon}</span>
                <span class="leading-none">{tool.label}</span>
              </div>
            ))}
            <!-- AI Tools button: pink-red → purple gradient -->
            <div class="flex items-center gap-0.5 rounded-[10px] px-1.5 py-1 text-[9px] font-semibold text-white whitespace-nowrap shadow-sm"
                 style="background: linear-gradient(135deg, rgb(230,77,128) 0%, rgb(153,51,230) 100%);">
              <span class="text-[10px] leading-none">✨</span>
              <span class="leading-none">Tools</span>
            </div>
            <!-- Language flag (white) -->
            <div class="bg-white rounded-[10px] px-1.5 py-1 text-[10px] leading-none shadow-sm">
              {flag}
            </div>
            <!-- Close X -->
            <div class="ml-auto text-[#0e0e18]/60 text-base leading-none pr-1">✕</div>
          </div>
        </div>

        <!-- iOS-style keyboard rows (light theme) -->
        <div class="bg-[#d1d4dc] px-1 pt-1.5 pb-1.5 space-y-1.5">
          <div class="flex justify-center gap-[3px]">
            {row1.map((ch) => (
              <div class="flex-1 max-w-[26px] py-1.5 text-center rounded-[5px] text-[12px] bg-white text-black font-normal shadow-[0_1px_0_rgba(0,0,0,0.35)]">
                {ch}
              </div>
            ))}
          </div>
          <div class="flex justify-center gap-[3px] px-[14px]">
            {row2.map((ch) => (
              <div class="flex-1 max-w-[26px] py-1.5 text-center rounded-[5px] text-[12px] bg-white text-black font-normal shadow-[0_1px_0_rgba(0,0,0,0.35)]">
                {ch}
              </div>
            ))}
          </div>
          <div class="flex justify-center gap-[3px]">
            <div class="px-1.5 py-1.5 text-center rounded-[5px] text-[10px] bg-[#abafb9] text-black font-medium shadow-[0_1px_0_rgba(0,0,0,0.35)]">⇧</div>
            {row3.map((ch) => (
              <div class="flex-1 max-w-[26px] py-1.5 text-center rounded-[5px] text-[12px] bg-white text-black font-normal shadow-[0_1px_0_rgba(0,0,0,0.35)]">
                {ch}
              </div>
            ))}
            <div class="px-1.5 py-1.5 text-center rounded-[5px] text-[10px] bg-[#abafb9] text-black font-medium shadow-[0_1px_0_rgba(0,0,0,0.35)]">⌫</div>
          </div>
          <div class="flex justify-center gap-[3px]">
            <div class="px-2 py-1.5 rounded-[5px] text-[10px] bg-[#abafb9] text-black font-medium shadow-[0_1px_0_rgba(0,0,0,0.35)]">123</div>
            <div class="px-1.5 py-1.5 rounded-[5px] text-[10px] bg-[#abafb9] text-black font-medium shadow-[0_1px_0_rgba(0,0,0,0.35)]">🌐</div>
            <div class="flex-1 py-1.5 rounded-[5px] text-[10px] text-center bg-white text-black font-medium shadow-[0_1px_0_rgba(0,0,0,0.35)]">space</div>
            <div class="px-2 py-1.5 rounded-[5px] text-[10px] bg-[#abafb9] text-black font-medium shadow-[0_1px_0_rgba(0,0,0,0.35)]">return</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
